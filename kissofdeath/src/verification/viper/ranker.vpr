method test_weighted_average()
{
    var scores: Seq[Int] := Seq(fp_half(), fp_mul(fp_from_int(4), fp_div(fp_one(), fp_from_int(5))), fp_point_three())
    var weights: Seq[Int] := Seq(fp_one(), fp_mul(fp_from_int(2), fp_one()), fp_one())
    var avg: Int := weighted_average(scores, weights)
    assert fp_is_valid(avg)
}

method test_exponential_decay()
{
    var scores: Seq[Int] := Seq(fp_one(), fp_one(), fp_one(), fp_one())
    var decay: Int := fp_mul(fp_from_int(9), fp_div(fp_one(), fp_from_int(10)))
    var decayed: Seq[Int] := exponential_decay(scores, decay)
    assert |decayed| == 4
    assert fp_is_valid(decayed[0])
    assert fp_is_valid(decayed[1])
    assert fp_is_valid(decayed[2])
    assert fp_is_valid(decayed[3])
}

method test_normalize_scores()
{
    var scores: Seq[Int] := Seq(fp_from_int(10), fp_from_int(20), fp_from_int(30), fp_from_int(40))
    var normed: Seq[Int] := normalize_scores_static(scores)
    assert |normed| == 4
    assert fp_is_valid(normed[0])
    assert fp_is_valid(normed[3])
}

method test_export_import_model()
{
    var r: Ref := ranker_init(4, 8, 42)

    unfold valid_ranker(r)
    fold valid_ranker_ro(r)

    var m: Ref := export_model(r)

    unfold valid_ranker_ro(r)
    fold valid_ranker(r)

    var r2: Ref := ranker_init(2, 4, 0)
    import_model(r2, m)

    unfold valid_ranker(r2)
    unfold valid_model_file(m)
    assert r2.num_ngrams == m.model_num_ngrams
    assert r2.num_hash_functions == m.model_num_hash_funcs
    assert r2.ranker_seed == m.model_seed
    assert r2.ngram_weights == m.model_weights
    assert r2.lsh_hash_params == m.model_hash_params
    fold valid_model_file(m)
    fold valid_ranker(r2)

    ranker_deinit(r)
    ranker_deinit(r2)
}

