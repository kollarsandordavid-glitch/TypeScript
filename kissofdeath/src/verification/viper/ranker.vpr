method test_estimate_jaccard()
{
    var set1: Ref := bitset_init(128)
    bitset_set(set1, 0)
    bitset_set(set1, 64)
    var set2: Ref := bitset_init(128)
    bitset_set(set2, 0)

    unfold valid_bitset(set1)
    fold valid_bitset_ro(set1)
    unfold valid_bitset(set2)
    fold valid_bitset_ro(set2)

    var est: Int := estimate_jaccard(set1, set2)
    assert est >= fp_zero() && est <= fp_one()
    assert fp_is_valid(est)

    unfold valid_bitset_ro(set1)
    fold valid_bitset(set1)
    unfold valid_bitset_ro(set2)
    fold valid_bitset(set2)

    bitset_deinit(set1)
    bitset_deinit(set2)
}

method test_estimate_jaccard_empty()
{
    var set1: Ref := bitset_init(64)
