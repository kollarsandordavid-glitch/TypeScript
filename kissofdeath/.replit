entrypoint = "src/main.zig"

[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = [
  "zig",
  "python3",
  "python3Packages.pip",
  "futhark",
  "z3",
  "llvm_17",
  "clang_17",
  "lld_17",
  "gcc",
  "gnumake",
  "curl",
  "gnutar",
  "gzip",
  "unzip",
  "yosys",
  "nextpnr",
  "icestorm",
  "verilator",
  "nodejs",
  "bash",
  "pkg-config",
]

[env]
PATH = "${REPL_HOME}/.local/bin:${REPL_HOME}/zig-out/bin:${PATH}"
LD_LIBRARY_PATH = "${REPL_HOME}/.local/lib:${LD_LIBRARY_PATH}"
JAIDE_HOME = "${REPL_HOME}"
ZIG_OPT_LEVEL = "ReleaseFast"

[languages]

[languages.zig]
pattern = "**/*.zig"
[languages.zig.languageServer]
start = "zls"

[languages.python]
pattern = "**/*.py"
[languages.python.languageServer]
start = "pylsp"

[languages.futhark]
pattern = "**/*.fut"

[languages.lean]
pattern = "**/*.lean"

[languages.verilog]
pattern = "**/*.v"

[languages.cryptol]
pattern = "**/*.cry"

[languages.saw]
pattern = "**/*.saw"

[languages.circom]
pattern = "**/*.circom"

[languages.viper]
pattern = "**/*.vpr"

[languages.tcl]
pattern = "**/*.tcl"

[languages.bash]
pattern = "**/*.sh"
[languages.bash.languageServer]
start = "bash-language-server start"

[languages.pcf]
pattern = "**/*.pcf"

[languages.jsonl]
pattern = "**/*.jsonl"

[[workflows.workflow]]
name = "Run JAIDE"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "zig build run"

[[workflows.workflow]]
name = "Build"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "zig build"

[[workflows.workflow]]
name = "Build Release"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "zig build -Doptimize=ReleaseFast"

[[workflows.workflow]]
name = "Run Tests"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "zig build test"

[[workflows.workflow]]
name = "Run Tensor Tests"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "zig build test-tensor"

[[workflows.workflow]]
name = "Run Memory Tests"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "zig build test-memory"

[[workflows.workflow]]
name = "Run Distributed"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "zig build run-distributed"

[[workflows.workflow]]
name = "Run Inference Server"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "zig build -Doptimize=ReleaseFast && ./zig-out/bin/jaide-inference-server"
waitForPort = 8080

[[workflows.workflow]]
name = "Build GPU"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "zig build -Dgpu=true -Doptimize=ReleaseFast"

[[workflows.workflow]]
name = "Futhark Compile C"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "futhark c src/hw/accel/futhark_kernels.fut -o src/hw/accel/futhark_kernels"

[[workflows.workflow]]
name = "Futhark Compile CUDA"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "futhark cuda src/hw/accel/futhark_kernels.fut -o src/hw/accel/futhark_kernels"

[[workflows.workflow]]
name = "Modal Setup"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash src/scripts/modal_setup.sh"

[[workflows.workflow]]
name = "Modal Train"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "modal run src/scripts/modal_train.py --epochs 10 --batch-size 32 --dim 128 --layers 4"

[[workflows.workflow]]
name = "Modal Distributed Train"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "modal run src/scripts/modal_distributed_train.py --epochs 20 --batch-size 256"

[[workflows.workflow]]
name = "FPGA Synth"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "yosys -p 'read_verilog hw/fpga/top_level.v; synth_ice40 -top top_level -json hw/fpga/top_level.json'"

[[workflows.workflow]]
name = "FPGA Place and Route"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "nextpnr-ice40 --hx8k --json hw/fpga/top_level.json --pcf hw/fpga/constraints.pcf --asc hw/fpga/top_level.asc"

[[workflows.workflow]]
name = "Circom Compile"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "circom src/zk/inference_trace.circom --r1cs --wasm --sym -o build/zk/"

[[workflows.workflow]]
name = "Verilator Lint"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "verilator --lint-only hw/fpga/top_level.v"

[[workflows.workflow]]
name = "Install Dependencies"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash src/build.sh install-all"

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8443
externalPort = 443

[deployment]
run = "zig build -Doptimize=ReleaseFast && ./zig-out/bin/jaide-inference-server"
deploymentTarget = "autoscale"

[unitTest]
language = "zig"

[gitHubImport]
requiredFiles = ["build.zig", "src/main.zig"]
